  "bugs": {
    "url": "https://github.com/OmarCastro/its-i18n/issues"
  },
  "homepage": "https://omarcastro.github.io/its-i18n/",
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@cspell/eslint-plugin": "^10.0.1",
    "@dagrejs/dagre": "^3.0.0",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "badge-maker": "^6.0.0",
    "c8": "^11.0.0",
    "codemirror": "^6.0.2",
    "cspell": "^10.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-unicorn": "^70.0.0",
    "expect": "^30.4.1",
    "image-size": "^2.0.2",
    "js-yaml": "^5.2.1",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "minimatch": "^10.2.5",
    "mkcert": "^3.2.0",
    "object-inspect": "^1.13.4",
    "open": "^11.0.0",
    "prismjs": "^1.30.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3"
  }
}
