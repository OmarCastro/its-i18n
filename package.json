{
  "name": "its-i18n",
  "version": "0.4.0",
  "description": "An i18n web component",
  "main": "src/entrypoint/node.js",
  "type": "module",
  "files": [
    "README.md",
    "CHANGELOG.md",
    "src",
    "dist",
    "test-utils/",
    "jsconfig.json"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "node ./dev-tools/run.js build",
    "build:github-action": "node ./dev-tools/run.js build:github-action",
    "test": "node ./dev-tools/run.js test",
    "lint": "node ./dev-tools/run.js lint",
    "linc": "node ./dev-tools/run.js linc",
    "format": "node ./dev-tools/run.js format",
    "formac": "node ./dev-tools/run.js formac",
    "dev": "node ./dev-tools/run.js dev",
    "dev:open": "node ./dev-tools/run.js dev:open",
    "dev-server": "node ./dev-tools/run.js dev-server",
    "dev-server:open": "node ./dev-tools/run.js dev-server:open",
    "help": "node ./dev-tools/run.js help"
  },
  "imports": {
    "#unit-test": "./test-utils/unit/test.util.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmarCastro/its-i18n.git"
  },
  "author": "Omar Castro",
